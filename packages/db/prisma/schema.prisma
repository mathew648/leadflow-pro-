  children    CatalogCategory[] @relation("CategoryTree")
  catalogItems CatalogItem[]

  @@index([tenantId])
  @@map("catalog_categories")
}

model CatalogItem {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String  @db.Uuid @map("tenant_id")
  categoryId  String? @db.Uuid @map("category_id")

  code        String? @db.VarChar(50)
  name        String  @db.VarChar(200)
  description String?
  type        String  @db.VarChar(30)
  unit        String  @db.VarChar(30)

  costPriceCents  Int     @default(0) @map("cost_price_cents")
  sellPriceCents  Int     @map("sell_price_cents")
