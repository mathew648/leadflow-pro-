generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [uuid_ossp(map: "uuid-ossp"), pg_trgm, unaccent]
}

// ============================================================
// ENUMS
// ============================================================

enum SubscriptionTier {
  starter
  growth
  pro
  enterprise
  // New plan set (2026)
  sole_trader
  company
  website
  non_tradie
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  cancelled
  paused
}

enum UserRole {
  owner
  admin
  manager
  technician
  sales
  viewer
}

enum UserStatus {
  active
  inactive
  invited
}

enum LeadSource {
  meta_ads
  google_ads
  tiktok_ads
  linkedin_ads
  website
  landing_page
  whatsapp
  messenger
  email
  sms
  manual
  phone
  referral
  walk_in
}

enum Urgency {
  emergency
  urgent
  normal
  flexible
}

enum LeadStatus {
  active
  converted
  lost
  duplicate
  spam
}

enum PropertyType {
  residential
  commercial
  industrial
  strata
}

enum QuoteStatus {
  draft
  sent
  viewed
  approved
  rejected
  changes_requested
  expired
  converted
}

enum JobStatus {
  pending
  scheduled
  dispatched
  in_progress
  on_hold
  completed
  cancelled
  invoiced
}

enum JobPriority {
  emergency
  high
  normal
  low
}

enum InvoiceType {
  deposit
  progress
  final
  recurring
  credit_note
}

enum InvoiceStatus {
  draft
  sent
  viewed
  partial
  paid
  overdue
  cancelled
  written_off
}

enum PaymentStatus {
  pending
  completed
  failed
  refunded
}

enum PaymentGateway {
  stripe
  windcave
  paypal
  manual
}

enum MessageChannel {
  sms
  email
  whatsapp
  messenger
  internal
}

enum MessageDirection {
  inbound
  outbound
}

enum WorkflowTriggerType {
  lead_created
  lead_stage_changed
  lead_assigned
  quote_sent
  quote_viewed
  quote_approved
  quote_rejected
  job_created
  job_started
  job_completed
  invoice_sent
  invoice_paid
  invoice_overdue
  scheduled
  manual
}

// ============================================================
// TENANTS
// ============================================================

model Tenant {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug          String   @unique @db.VarChar(100)
  businessName  String   @db.VarChar(200) @map("business_name")
  // Referral program
  referralCode       String?  @unique @db.VarChar(20) @map("referral_code")
  referredByTenantId String?  @db.Uuid @map("referred_by_tenant_id")
  referralRewardedAt DateTime? @map("referral_rewarded_at")
  abn           String?  @db.VarChar(20)
  nzbn          String?  @db.VarChar(20)
  email         String   @db.VarChar(255)
  phone         String?  @db.VarChar(30)
  websiteUrl    String?  @db.VarChar(500) @map("website_url")

  streetAddress String?  @db.VarChar(200) @map("street_address")
  suburb        String?  @db.VarChar(100)
  city          String?  @db.VarChar(100)
  state         String?  @db.VarChar(50)
  postcode      String?  @db.VarChar(10)
  country       String   @default("AU") @db.Char(2)
  latitude      Decimal? @db.Decimal(10, 8)
  longitude     Decimal? @db.Decimal(11, 8)

  tradeTypes    String[] @map("trade_types")
  timezone      String   @default("Australia/Sydney")
  currency      String   @default("AUD") @db.Char(3)
  dateFormat    String   @default("DD/MM/YYYY") @map("date_format")

  logoUrl         String?  @db.VarChar(500) @map("logo_url")
  primaryColor    String?  @db.Char(7) @map("primary_color")
  secondaryColor  String?  @db.Char(7) @map("secondary_color")

  gstRegistered   Boolean  @default(true) @map("gst_registered")
  gstRate         Decimal  @default(0.10) @db.Decimal(5, 4) @map("gst_rate")
  taxNumber       String?  @db.VarChar(50) @map("tax_number")

  accountType         String              @default("tradie") @db.VarChar(20) @map("account_type")
  subscriptionStatus  SubscriptionStatus  @default(trialing) @map("subscription_status")
  trialEndsAt         DateTime?           @map("trial_ends_at")
  onboardedAt         DateTime?           @map("onboarded_at")
  onboardingStep      String?             @db.VarChar(50) @map("onboarding_step")
  stripeAccountId     String?             @db.VarChar(200) @map("stripe_account_id")
  status              String              @default("active") @db.VarChar(20)

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  // Relations
  settings        TenantSettings?
  subscription    Subscription?
  users           User[]
  pipelineStages  PipelineStage[]
  leads           Lead[]
  contacts        Contact[]
  customers       Customer[]
  properties      Property[]
  catalogItems    CatalogItem[]
  catalogCategories CatalogCategory[]
  quotes          Quote[]
  jobs            Job[]
  invoices        Invoice[]
  payments        Payment[]
  messages        Message[]
  automations     AutomationWorkflow[]
  accountingConnections AccountingConnection[]
  leadSources     LeadSourceConfig[]
  auditLogs       AuditLog[]
  serviceAgreements ServiceAgreement[]

  @@map("tenants")
}

model TenantSettings {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String @unique @db.Uuid @map("tenant_id")

  businessHours         Json    @default("{\"monday\":{\"open\":\"08:00\",\"close\":\"17:00\",\"enabled\":true},\"tuesday\":{\"open\":\"08:00\",\"close\":\"17:00\",\"enabled\":true},\"wednesday\":{\"open\":\"08:00\",\"close\":\"17:00\",\"enabled\":true},\"thursday\":{\"open\":\"08:00\",\"close\":\"17:00\",\"enabled\":true},\"friday\":{\"open\":\"08:00\",\"close\":\"17:00\",\"enabled\":true},\"saturday\":{\"open\":\"08:00\",\"close\":\"12:00\",\"enabled\":false},\"sunday\":{\"open\":null,\"close\":null,\"enabled\":false}}") @map("business_hours")
  invoicePrefix         String  @default("INV") @db.VarChar(20) @map("invoice_prefix")
  invoiceNextNumber     Int     @default(1001) @map("invoice_next_number")
  invoicePaymentTerms   Int     @default(14) @map("invoice_payment_terms")
  invoiceFooterText     String? @map("invoice_footer_text")
  invoiceBankDetails    Json?   @map("invoice_bank_details")
  quotePrefix           String  @default("QTE") @db.VarChar(20) @map("quote_prefix")
  quoteNextNumber       Int     @default(1001) @map("quote_next_number")
  quoteValidityDays     Int     @default(30) @map("quote_validity_days")
  quoteTermsConditions  String? @map("quote_terms_conditions")
  quoteDepositPercent   Decimal @default(30) @db.Decimal(5, 2) @map("quote_deposit_percent")
  jobPrefix             String  @default("JOB") @db.VarChar(20) @map("job_prefix")
  jobNextNumber         Int     @default(1001) @map("job_next_number")
  requireCustomerSignoff Boolean @default(true) @map("require_customer_signoff")
  notifyNewLeadEmail    Boolean @default(true) @map("notify_new_lead_email")
  notifyNewLeadSms      Boolean @default(true) @map("notify_new_lead_sms")
  notifyQuoteViewed     Boolean @default(true) @map("notify_quote_viewed")
  notifyQuoteApproved   Boolean @default(true) @map("notify_quote_approved")
  notifyPaymentReceived Boolean @default(true) @map("notify_payment_received")
  leadAssignmentStrategy String @default("round_robin") @db.VarChar(50) @map("lead_assignment_strategy")
  defaultLeadAssigneeId  String? @db.Uuid @map("default_lead_assignee_id")
  autoSendReviewRequest Boolean @default(true) @map("auto_send_review_request")
  reviewRequestDelayHours Int   @default(2) @map("review_request_delay_hours")
  googlePlaceId         String? @db.VarChar(200) @map("google_place_id")
  googleReviewUrl       String? @map("google_review_url")
  facebookPageId        String? @db.VarChar(100) @map("facebook_page_id")
  xeroTenantId          String? @db.VarChar(100) @map("xero_tenant_id")
  stripeAccountId       String? @db.VarChar(100) @map("stripe_account_id")

  // Online booking widget (public /book/<slug> page).
  bookingEnabled       Boolean @default(false) @map("booking_enabled")
  bookingServices      Json    @default("[]") @map("booking_services")        // [{ name, durationMin?, priceCents? }]
  bookingSlotMinutes   Int     @default(60) @map("booking_slot_minutes")
  bookingLeadTimeHours Int     @default(24) @map("booking_lead_time_hours")   // earliest bookable from now
  bookingAdvanceDays   Int     @default(30) @map("booking_advance_days")      // furthest bookable ahead
  bookingInstructions  String? @map("booking_instructions")

  updatedAt DateTime @updatedAt @map("updated_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@map("tenant_settings")
}

// ============================================================
// SUBSCRIPTIONS
// ============================================================

model Subscription {
  id        String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String             @unique @db.Uuid @map("tenant_id")
  tier      SubscriptionTier
  status    SubscriptionStatus

  billingCycle       String  @default("monthly") @db.VarChar(20) @map("billing_cycle")
  basePriceCents     Int     @map("base_price_cents")
  userCount          Int     @default(1) @map("user_count")
  userPriceCents     Int     @default(0) @map("user_price_cents")
  maxUsers           Int     @default(1) @map("max_users")
  maxLeadsPerMonth   Int     @default(500) @map("max_leads_per_month")
  storageGb          Int     @default(5) @map("storage_gb")

  stripeSubscriptionId String? @db.VarChar(200) @map("stripe_subscription_id")
  stripeCustomerId     String? @db.VarChar(200) @map("stripe_customer_id")

  currentPeriodStart DateTime? @map("current_period_start")
  currentPeriodEnd   DateTime? @map("current_period_end")
  trialEnd           DateTime? @map("trial_end")
  cancelledAt        DateTime? @map("cancelled_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@map("subscriptions")
}

// ============================================================
// USERS
// ============================================================

model User {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String     @db.Uuid @map("tenant_id")
  email     String     @db.VarChar(255)
  firstName String     @db.VarChar(100) @map("first_name")
  lastName  String     @db.VarChar(100) @map("last_name")
  phone     String?    @db.VarChar(30)
  avatarUrl String?    @db.VarChar(500) @map("avatar_url")
  role      UserRole   @default(technician)
  permissions Json     @default("{}") @db.JsonB

  tradeTypes      String[] @map("trade_types")
  licenceNumber   String?  @db.VarChar(100) @map("licence_number")
  licenceExpiry   DateTime? @map("licence_expiry")
  skills          String[]

  hourlyRateCents  Int?    @map("hourly_rate_cents")
  employmentType   String? @db.VarChar(30) @map("employment_type")

  passwordHash  String?  @db.VarChar(255) @map("password_hash")
  mfaEnabled    Boolean  @default(false) @map("mfa_enabled")
  mfaSecret     String?  @db.VarChar(100) @map("mfa_secret")

  lastLoginAt   DateTime? @map("last_login_at")
  lastLoginIp   String?   @db.VarChar(45) @map("last_login_ip")

  pushTokenIos      String? @db.VarChar(500) @map("push_token_ios")
  pushTokenAndroid  String? @db.VarChar(500) @map("push_token_android")

  status       UserStatus @default(invited)
  invitedAt    DateTime?  @map("invited_at")
  activatedAt  DateTime?  @map("activated_at")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  assignedLeads     Lead[]     @relation("AssignedLeads")
  assignedCustomers Customer[] @relation("AssignedCustomers")
  assignedJobs      Job[]      @relation("LeadTechnician")
  timeEntries     TimeEntry[]
  createdLeads    Lead[]        @relation("CreatedLeads")
  createdQuotes   Quote[]       @relation("CreatedQuotes")
  createdJobs     Job[]         @relation("CreatedJobs")
  locationPings   LocationPing[]
  auditLogs       AuditLog[]
  pushSubscriptions PushSubscription[]

  @@unique([email, tenantId])
  @@index([tenantId])
  @@map("users")
}

model PushSubscription {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid @map("user_id")
  tenantId  String   @db.Uuid @map("tenant_id")
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@map("push_subscriptions")
}

model RefreshToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid @map("user_id")
  token     String   @unique @db.VarChar(500)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("refresh_tokens")
}

// ============================================================
// PIPELINE & LEADS
// ============================================================

model PipelineStage {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String  @db.Uuid @map("tenant_id")
  name      String  @db.VarChar(100)
  slug      String  @db.VarChar(50)
  color     String? @db.Char(7)
  position  Int
  isDefault Boolean @default(false) @map("is_default")
  isWon     Boolean @default(false) @map("is_won")
  isLost    Boolean @default(false) @map("is_lost")
  slaHours  Int?    @map("sla_hours")

  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  leads     Lead[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("pipeline_stages")
}

model Lead {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String     @db.Uuid @map("tenant_id")
  leadNumber  String?    @db.VarChar(20) @map("lead_number")

  firstName   String     @db.VarChar(100) @map("first_name")
  lastName    String?    @db.VarChar(100) @map("last_name")
  email       String?    @db.VarChar(255)
  phone       String?    @db.VarChar(30)
  companyName String?    @db.VarChar(200) @map("company_name")

  source            LeadSource
  sourceDetail      String?    @db.VarChar(200) @map("source_detail")
  sourceCampaignId  String?    @db.VarChar(200) @map("source_campaign_id")
  sourceAdId        String?    @db.VarChar(200) @map("source_ad_id")
  sourceFormId      String?    @db.VarChar(200) @map("source_form_id")
  utmSource         String?    @db.VarChar(100) @map("utm_source")
  utmMedium         String?    @db.VarChar(100) @map("utm_medium")
  utmCampaign       String?    @db.VarChar(100) @map("utm_campaign")
  utmContent        String?    @db.VarChar(100) @map("utm_content")
  utmTerm           String?    @db.VarChar(100) @map("utm_term")
  referrerCustomerId String?   @db.Uuid @map("referrer_customer_id")

  serviceRequired   String?    @map("service_required")
  serviceCategory   String?    @db.VarChar(50) @map("service_category")
  propertyAddress   String?    @db.VarChar(300) @map("property_address")
  suburb            String?    @db.VarChar(100)
  postcode          String?    @db.VarChar(10)
  latitude          Decimal?   @db.Decimal(10, 8)
  longitude         Decimal?   @db.Decimal(11, 8)
  propertyType      PropertyType? @map("property_type")
  urgency           Urgency    @default(normal)
  estimatedValueCents Int?     @map("estimated_value_cents")
  preferredStartDate DateTime? @map("preferred_start_date")
  notes             String?

  stageId         String?    @db.Uuid @map("stage_id")
  stageChangedAt  DateTime   @default(now()) @map("stage_changed_at")
  assignedToId    String?    @db.Uuid @map("assigned_to_id")
  assignedAt      DateTime?  @map("assigned_at")

  aiScore               Int?     @map("ai_score")
  aiCloseProbability    Decimal? @db.Decimal(5, 4) @map("ai_close_probability")
  aiEstimatedValueCents Int?     @map("ai_estimated_value_cents")
  aiNextAction          String?  @map("ai_next_action")
  aiScoredAt            DateTime? @map("ai_scored_at")

  status               LeadStatus @default(active)
  lostReason           String?    @db.VarChar(200) @map("lost_reason")
  convertedToCustomerId String?   @db.Uuid @map("converted_to_customer_id")
  convertedAt          DateTime?  @map("converted_at")

  rawPayload    Json     @default("{}") @db.JsonB @map("raw_payload")
  customFields  Json     @default("{}") @db.JsonB @map("custom_fields")
  tags          String[]

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  createdById String?   @db.Uuid @map("created_by_id")

  tenant      Tenant        @relation(fields: [tenantId], references: [id])
  stage       PipelineStage? @relation(fields: [stageId], references: [id])
  assignedTo  User?         @relation("AssignedLeads", fields: [assignedToId], references: [id])
  createdBy   User?         @relation("CreatedLeads", fields: [createdById], references: [id])
  activities  LeadActivity[]
  quotes      Quote[]

  @@index([tenantId, stageId])
  @@index([tenantId, status])
  @@index([phone, tenantId])
  @@index([email, tenantId])
  @@index([tenantId, createdAt(sort: Desc)])
  @@map("leads")
}

model LeadActivity {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @db.Uuid @map("tenant_id")
  leadId      String   @db.Uuid @map("lead_id")
  type        String   @db.VarChar(50)
  description String?
  metadata    Json     @default("{}") @db.JsonB
  userId      String?  @db.Uuid @map("user_id")
  createdAt   DateTime @default(now()) @map("created_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt(sort: Desc)])
  @@map("lead_activities")
}

// ============================================================
// CONTACTS
// ============================================================

model Contact {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String @db.Uuid @map("tenant_id")

  firstName   String  @db.VarChar(100) @map("first_name")
  lastName    String? @db.VarChar(100) @map("last_name")
  email       String? @db.VarChar(255)
  phone       String? @db.VarChar(30)
  mobile      String? @db.VarChar(30)
  jobTitle    String? @db.VarChar(100) @map("job_title")
  customerId  String? @db.Uuid @map("customer_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  @@index([tenantId])
  @@map("contacts")
}

// ============================================================
// CUSTOMERS & PROPERTIES
// ============================================================

model Customer {
  id          String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String @db.Uuid @map("tenant_id")
  customerNumber String? @db.VarChar(20) @map("customer_number")
  type        String @default("residential") @db.VarChar(20)

  firstName   String? @db.VarChar(100) @map("first_name")
  lastName    String? @db.VarChar(100) @map("last_name")
  companyName String? @db.VarChar(200) @map("company_name")
  email       String? @db.VarChar(255)
  phone       String? @db.VarChar(30)
  mobile      String? @db.VarChar(30)

  billingStreet   String? @db.VarChar(200) @map("billing_street")
  billingSuburb   String? @db.VarChar(100) @map("billing_suburb")
  billingCity     String? @db.VarChar(100) @map("billing_city")
  billingState    String? @db.VarChar(50) @map("billing_state")
  billingPostcode String? @db.VarChar(10) @map("billing_postcode")
  billingCountry  String  @default("AU") @db.Char(2) @map("billing_country")

  sourceLeadId   String? @db.Uuid @map("source_lead_id")
  assignedToId   String? @db.Uuid @map("assigned_to_id")
  tags           String[]

  preferredContactMethod  String? @db.VarChar(20) @map("preferred_contact_method")
  communicationOptOut     Boolean @default(false) @map("communication_opt_out")
  marketingOptIn          Boolean @default(true) @map("marketing_opt_in")

  creditLimitCents    Int? @map("credit_limit_cents")
  paymentTermsDays    Int  @default(14) @map("payment_terms_days")

  xeroContactId String? @db.VarChar(200) @map("xero_contact_id")
  myobCardId    String? @db.VarChar(200) @map("myob_card_id")

  internalNotes  String? @map("internal_notes")
  customFields   Json    @default("{}") @db.JsonB @map("custom_fields")

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  createdById String?   @db.Uuid @map("created_by_id")

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  assignedTo  User?       @relation("AssignedCustomers", fields: [assignedToId], references: [id])
  properties  Property[]
  contacts    Contact[]
  quotes      Quote[]
  jobs        Job[]
  invoices    Invoice[]
  payments    Payment[]
  messages    Message[]
  serviceAgreements ServiceAgreement[]

  @@index([tenantId])
  @@index([email, tenantId])
  @@index([phone, tenantId])
  @@map("customers")
}

model Property {
  id          String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String @db.Uuid @map("tenant_id")
  customerId  String @db.Uuid @map("customer_id")
  nickname    String? @db.VarChar(100)

  streetAddress String  @db.VarChar(200) @map("street_address")
  suburb        String? @db.VarChar(100)
  city          String? @db.VarChar(100)
  state         String? @db.VarChar(50)
  postcode      String? @db.VarChar(10)
  country       String  @default("AU") @db.Char(2)
  latitude      Decimal? @db.Decimal(10, 8)
  longitude     Decimal? @db.Decimal(11, 8)

  propertyType PropertyType? @map("property_type")
  ownerType    String?       @db.VarChar(30) @map("owner_type")
  bedrooms     Int?
  bathrooms    Int?
  stories      Int?
  roofType     String? @db.VarChar(50) @map("roof_type")
  yearBuilt    Int?    @map("year_built")

  accessNotes    String? @map("access_notes")
  accessPhotoUrl String? @db.VarChar(500) @map("access_photo_url")
  compliance     Json    @default("[]") @db.JsonB
  notes          String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  customer Customer  @relation(fields: [customerId], references: [id])
  quotes   Quote[]
  jobs     Job[]
  serviceAgreements ServiceAgreement[]

  @@index([customerId])
  @@index([tenantId])
  @@map("properties")
}

// ============================================================
// CATALOG
// ============================================================

