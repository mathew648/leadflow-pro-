# ============================================================
# LeadFlow Pro — Environment Variables
# Copy to .env and fill in values
# ============================================================

# App
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# Database
DATABASE_URL=postgresql://lfp:lfp_dev_password@localhost:5432/leadflow_dev?schema=public
DATABASE_POOL_MAX=20

# Redis
REDIS_URL=redis://localhost:6379

# JWT (generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem)
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_ACCESS_EXPIRY=900
JWT_REFRESH_EXPIRY=2592000

# Encryption (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=your-32-byte-hex-encryption-key-here

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=LeadFlow Pro <noreply@leadflowpro.com>

# SMS (Vonage)
VONAGE_API_KEY=xxxxxxxx
VONAGE_API_SECRET=xxxxxxxxxxxx
VONAGE_FROM_NUMBER=LeadFlow

# Storage (Cloudflare R2 / S3-compatible)
R2_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxx
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_BUCKET_NAME=leadflow-dev
R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev

# AI (Anthropic)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# Payments (Stripe)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
STRIPE_PLATFORM_FEE_PERCENT=0.5

# Xero
XERO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxx
XERO_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
XERO_REDIRECT_URI=http://localhost:4000/api/v1/integrations/xero/callback

# Meta (Facebook) Lead Ads
META_APP_ID=xxxxxxxxxxxx
META_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
META_VERIFY_TOKEN=your-webhook-verify-token

# Google
GOOGLE_ADS_DEVELOPER_TOKEN=xxxxxxxxxxxxxxxxxxxx
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxx

# reCAPTCHA / Turnstile
TURNSTILE_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Rate limiting
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX=1000

# Feature flags
ENABLE_AI_FEATURES=true
ENABLE_WEBSITE_BUILDER=false

# Platform super-admins who can access the admin panel (comma-separated emails)
PLATFORM_ADMIN_EMAILS=
