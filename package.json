{
  "name": "leadflow-pro",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:push": "turbo run db:push --filter=@lfp/db",
    "db:generate": "turbo run db:generate --filter=@lfp/db",
    "db:migrate": "turbo run db:migrate --filter=@lfp/db",
    "db:seed": "turbo run db:seed --filter=@lfp/db",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "demo": "./scripts/demo.sh",
    "demo:tunnel": "./scripts/demo-tunnel.sh"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "prettier": "^3.3.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  }
}
